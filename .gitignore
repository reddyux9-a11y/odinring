# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Environment files (comprehensive coverage)
*.env
*.env.*
*token.json*
*credentials.json*

# JSON files (ignore all, then allow specific ones)
*.json
# Exceptions: Allow legitimate JSON files that need to be tracked
!package.json
!package-lock.json
!firebase.json
!firestore.indexes.json
!jsconfig.json
!tsconfig.json
!components.json
!vercel.json
# Allow schema files
!**/firestore_schemas/*.json
!**/*schema*.json

# Firebase Service Account Files (CRITICAL: Contains private keys)
# These must remain ignored even with *.json pattern
firebase-service-account.json
*firebase-adminsdk*.json
studio-*.json
*-firebase-adminsdk-*.json

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore
# Additional credential file patterns
*-credentials.json
*-credential.json
service-account*.json
*-service-account*.json

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel
.vercelrc

# Data and databases
agenthub/agents/youtube/db

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/
**/node_modules/.cache/

# Mobile development
android-sdk/
