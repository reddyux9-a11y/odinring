  "data_flow": {
    "user_registration": {
      "steps": [
        "1. User fills registration form",
        "2. Frontend validates input",
        "3. POST /api/auth/register",
        "4. Backend validates and hashes password",
        "5. Backend creates user in Firestore",
        "6. Backend generates JWT token",
        "7. Frontend stores token and user_data in localStorage",
        "8. Frontend sets user in React state",
        "9. Navigate to /dashboard"
      ],
      "status": "LIVE"
    },
    "google_signin": {
      "steps": [
        "1. User clicks 'Sign in with Google'",
        "2. Firebase SDK initiates OAuth flow",
        "3. User authenticates with Google",
        "4. Firebase returns ID token",
        "5. Frontend sends token to backend",
        "6. Backend verifies Firebase token",
        "7. Backend creates/updates user in Firestore",
        "8. Backend generates JWT token",
        "9. Frontend stores token and user_data",
        "10. Navigate to /dashboard"
      ],
      "status": "LIVE",
      "retry_logic": "3 attempts with 500ms delay"
    },
    "auto_login": {
      "steps": [
        "1. App loads, AuthContext.checkAuthStatus() runs",
        "2. Check localStorage for token",
        "3. If token exists, instantly restore user from localStorage.user_data",
        "4. Background: GET /api/me to fetch fresh data",
        "5. Update localStorage and React state with fresh data"
      ],
      "status": "LIVE",
      "optimization": "instant restoration + background refresh"
    },
    "link_creation": {
      "steps": [
        "1. User fills link form",
        "2. Frontend: POST /api/links",
        "3. Backend calculates next order number",
        "4. Backend creates Link object with user_id",
        "5. Backend inserts into Firestore",
        "6. Frontend adds link to state",
        "7. UI updates automatically"
      ],
      "status": "LIVE"
    },
    "link_retrieval": {
      "steps": [
        "1. Dashboard loads",
        "2. Frontend: GET /api/links",
        "3. Backend queries Firestore: find({user_id}, sort by order)",
        "4. Backend returns array of links",
        "5. Frontend sets links in state",
        "6. UI renders links"
      ],
      "status": "LIVE"
    },
    "public_profile": {
      "steps": [
        "1. Visitor navigates to /profile/{username}",
        "2. Frontend: GET /api/profile/{username}",
        "3. Backend finds user by username",
        "4. Backend fetches active links",
        "5. Backend returns public profile + links",
        "6. Frontend renders profile"
      ],
      "status": "LIVE"
    },
    "link_click_tracking": {
      "steps": [
        "1. Visitor clicks link on public profile",
        "2. Frontend: POST /api/links/{link_id}/click",
        "3. Backend increments link.clicks",
        "4. Backend creates ring_analytics event",
        "5. Frontend redirects to link.url"
      ],
      "status": "LIVE"
    }
  },
